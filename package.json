{
  "name": "encedo-pgp-js",
  "version": "0.1.0",
  "description": "OpenPGP encryption/decryption/signing via Encedo HEM hardware security module",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "build": "rollup -c",
    "build:browser": "rollup -c --filter browser",
    "test:keygen": "node test/test-keygen.js",
    "test:wkd": "node test/test-wkd-lookup.js",
    "test:encrypt": "node test/test-encrypt.js",
    "test:decrypt": "node test/test-decrypt.js",
    "test:sign": "node test/test-sign.js",
    "serve": "serve .. -p 8080"
  },
  "dependencies": {
    "openpgp": "^6.0.0"
  },
  "devDependencies": {
    "@rollup/plugin-alias": "^6.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "rollup": "^4.60.1",
    "serve": "^14.0.0"
  }
}
